# Spinitron API token from Admin → Automation & API in the Spinitron web app.
# Required for live now-playing data in the sidebar.
VITE_SPINITRON_API_TOKEN=

# Optional override for the API base URL. Defaults to /api/spinitron, which Vite
# proxies to https://spinitron.com/api during local development.
# VITE_SPINITRON_API_BASE=/api/spinitron
